{
  "name": "guide-tour-plan",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:app": "next dev",
    "dev:osrm": "node scripts/osrm.mjs up",
    "dev:osrm:stop": "node scripts/osrm.mjs stop",
    "gtfs:probe": "tsx scripts/gtfs.ts",
    "build": "prisma generate && next build",
    "start": "next start --port 5176",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "worker": "tsx worker/index.ts",
    "worker:run-all": "tsx worker/index.ts --run-all"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "adm-zip": "^0.5.16",
    "cheerio": "^1.1.2",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.0",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.3.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
