generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SourceKind {
  OPEN_API
  FILE_DATA
  HTML_PAGE
  JSON_FEED
  INTERNAL_JOB
}

enum IngestRunStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum PlaceKind {
  TOUR
  FOOD
  STAY
}

enum PlanPreference {
  FASTEST
  LEAST_WALK
  LEAST_TRANSFER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED
}

enum GeometrySourceKind {
  BUS_JEJU_LINK
  GTFS
  OSM_RELATION
  GNSS_MATCHED
  OSRM_DERIVED
}

enum StopTimeSourceKind {
  OFFICIAL
  OFFICIAL_ANCHOR_INTERPOLATED
  DISTANCE_INTERPOLATED
  SEGMENT_PROFILE
}

enum ServiceDayClass {
  WEEKDAY
  SATURDAY
  SUNDAY_HOLIDAY
}

model Place {
  id              String           @id
  slug            String           @unique
  category        PlaceKind
  baseDisplayName String
  regionName      String
  latitude        Float
  longitude       Float
  sourceContentId String?          @unique
  sourceUrl       String?
  openingHoursRaw String?
  openingHoursJson Json?
  locales         PlaceLocale[]
  tourDetail      PlaceTourDetail?
  foodDetail      PlaceFoodDetail?
  stayDetail      PlaceStayDetail?
  walkFromLinks   WalkLink[]       @relation("PlaceOrigin")
  walkToLinks     WalkLink[]       @relation("PlaceDestination")
  planPlaces      PlanQueryPlace[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PlaceLocale {
  id            String  @id @default(cuid())
  placeId       String
  language      String
  displayName   String
  summary       String?
  categoryLabel String?
  place         Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([placeId, language])
}

model PlaceTourDetail {
  id              String  @id @default(cuid())
  placeId         String  @unique
  themeLabel      String?
  stayMinutesHint Int?
  place           Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PlaceFoodDetail {
  id          String  @id @default(cuid())
  placeId     String  @unique
  signature   String?
  openingNote String?
  place       Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model PlaceStayDetail {
  id            String  @id @default(cuid())
  placeId       String  @unique
  nightlyBudget String?
  checkInWindow String?
  place         Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Stop {
  id                String             @id
  displayName       String
  regionName        String
  latitude          Float
  longitude         Float
  derivedStopTimes  DerivedStopTime[]
  translations      StopTranslation[]
  projections       RoutePatternStopProjection[]
  routePatternStops RoutePatternStop[]
  stopTimes         StopTime[]
  walkFromLinks     WalkLink[]         @relation("StopOrigin")
  walkToLinks       WalkLink[]         @relation("StopDestination")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model StopTranslation {
  id          String @id @default(cuid())
  stopId      String
  language    String
  displayName String
  stop        Stop   @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([stopId, language])
}

model Route {
  id          String         @id
  shortName   String
  displayName String
  isActive    Boolean        @default(true)
  patterns    RoutePattern[]
  createdAt   DateTime       @default(now())
}

model RoutePattern {
  id               String             @id
  routeId          String
  scheduleId       String?
  externalRouteId  String?
  directionCode    String?
  waypointOrder    Int                @default(0)
  isActive         Boolean            @default(true)
  busType          Int?
  directionLabel   String
  displayName      String
  viaText          String?
  waypointText     String?
  serviceNote      String?
  effectiveDate    DateTime?
  route            Route              @relation(fields: [routeId], references: [id], onDelete: Cascade)
  scheduleSources  RoutePatternScheduleSource[]
  geometry         RoutePatternGeometry?
  stopProjections  RoutePatternStopProjection[]
  stops            RoutePatternStop[]
  segmentProfiles  SegmentTravelProfile[]
  trips            Trip[]
  vehicleDeviceMaps VehicleDeviceMap[]

  @@unique([externalRouteId, directionCode, waypointOrder])
}

model RoutePatternStop {
  id                String       @id @default(cuid())
  routePatternId    String
  stopId            String
  sequence          Int
  distanceFromStart Int
  routePattern      RoutePattern @relation(fields: [routePatternId], references: [id], onDelete: Cascade)
  stop              Stop         @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([routePatternId, sequence])
}

model RoutePatternGeometry {
  id            String             @id @default(cuid())
  routePatternId String            @unique
  sourceKind    GeometrySourceKind
  shapeRef      String?
  geometry      Json
  lengthMeters  Int
  confidence    Float              @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  routePattern  RoutePattern       @relation(fields: [routePatternId], references: [id], onDelete: Cascade)
}

model RoutePatternStopProjection {
  id                String             @id @default(cuid())
  routePatternId    String
  stopId            String
  sequence          Int
  offsetMeters      Int
  snapDistanceMeters Int
  sourceKind        GeometrySourceKind
  confidence        Float              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  routePattern      RoutePattern       @relation(fields: [routePatternId], references: [id], onDelete: Cascade)
  stop              Stop               @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([routePatternId, sequence])
  @@index([routePatternId, offsetMeters])
}

model ServiceCalendar {
  id       String @id
  label    String
  weekdays String
  trips    Trip[]
}

model Trip {
  id                String          @id
  routePatternId    String
  serviceCalendarId String
  scheduleSourceId  String?
  headsign          String
  startTime         String
  rowLabel          String?
  routePattern      RoutePattern    @relation(fields: [routePatternId], references: [id], onDelete: Cascade)
  scheduleSource    RoutePatternScheduleSource? @relation(fields: [scheduleSourceId], references: [id], onDelete: SetNull)
  serviceCalendar   ServiceCalendar @relation(fields: [serviceCalendarId], references: [id], onDelete: Cascade)
  derivedStopTimes  DerivedStopTime[]
  stopTimes         StopTime[]

  @@index([scheduleSourceId])
}

model RoutePatternScheduleSource {
  id            String       @id @default(cuid())
  routePatternId String
  scheduleId    String
  variantKey    String       @default("default")
  sourceLabel   String?
  effectiveDate DateTime?
  isActive      Boolean      @default(true)
  routePattern  RoutePattern @relation(fields: [routePatternId], references: [id], onDelete: Cascade)
  trips         Trip[]

  @@unique([scheduleId, variantKey, routePatternId])
  @@index([scheduleId])
  @@index([routePatternId])
}

model StopTime {
  id               String  @id @default(cuid())
  tripId           String
  stopId           String
  sequence         Int
  arrivalMinutes   Int
  departureMinutes Int
  isEstimated      Boolean @default(false)
  timeSource       StopTimeSourceKind @default(OFFICIAL)
  confidence       Float   @default(1)
  trip             Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop             Stop    @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([tripId, sequence])
  @@index([stopId, departureMinutes])
}

model DerivedStopTime {
  id                  String             @id @default(cuid())
  tripId              String
  stopId              String
  sequence            Int
  arrivalMinutes      Int
  departureMinutes    Int
  timeSource          StopTimeSourceKind @default(OFFICIAL_ANCHOR_INTERPOLATED)
  confidence          Float              @default(0)
  anchorStartSequence Int?
  anchorEndSequence   Int?
  trip                Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop                Stop               @relation(fields: [stopId], references: [id], onDelete: Cascade)

  @@unique([tripId, sequence])
  @@index([stopId, departureMinutes])
}

model WalkLink {
  id              String  @id @default(cuid())
  kind            String
  fromPlaceId     String?
  toPlaceId       String?
  fromStopId      String?
  toStopId        String?
  durationMinutes Int
  distanceMeters  Int
  rank            Int     @default(1)
  isPrecomputed   Boolean @default(true)
  fromPlace       Place?  @relation("PlaceOrigin", fields: [fromPlaceId], references: [id], onDelete: Cascade)
  toPlace         Place?  @relation("PlaceDestination", fields: [toPlaceId], references: [id], onDelete: Cascade)
  fromStop        Stop?   @relation("StopOrigin", fields: [fromStopId], references: [id], onDelete: Cascade)
  toStop          Stop?   @relation("StopDestination", fields: [toStopId], references: [id], onDelete: Cascade)

  @@index([fromPlaceId])
  @@index([toPlaceId])
  @@index([fromStopId])
  @@index([toStopId])
}

model VehicleDeviceMap {
  id              String       @id @default(cuid())
  routePatternId  String
  deviceId        String
  externalRouteId String?
  confidence      Float        @default(1)
  refreshedAt     DateTime
  routePattern    RoutePattern @relation(fields: [routePatternId], references: [id], onDelete: Cascade)

  @@unique([routePatternId, deviceId])
  @@index([deviceId])
  @@index([refreshedAt])
}

model GnssObservation {
  id          String   @id @default(cuid())
  deviceId    String
  observedAt  DateTime
  collectedAt DateTime @default(now())
  latitude    Float
  longitude   Float
  raw         Json?

  @@unique([deviceId, observedAt, latitude, longitude])
  @@index([deviceId, observedAt])
  @@index([observedAt])
}

model SegmentTravelProfile {
  id               String          @id @default(cuid())
  routePatternId   String
  fromSequence     Int
  toSequence       Int
  serviceDayClass  ServiceDayClass
  bucketStartMinute Int
  medianDurationSec Int
  p90DurationSec   Int
  medianSpeedKph   Float
  sampleCount      Int
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  routePattern     RoutePattern    @relation(fields: [routePatternId], references: [id], onDelete: Cascade)

  @@unique([routePatternId, fromSequence, toSequence, serviceDayClass, bucketStartMinute])
  @@index([routePatternId, serviceDayClass, bucketStartMinute])
}

model TurnDelayProfile {
  id               String          @id @default(cuid())
  fromOsmNodeId    String
  viaOsmNodeId     String
  toOsmNodeId      String
  serviceDayClass  ServiceDayClass
  bucketStartMinute Int
  penaltySec       Int
  sampleCount      Int
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([fromOsmNodeId, viaOsmNodeId, toOsmNodeId, serviceDayClass, bucketStartMinute])
  @@index([serviceDayClass, bucketStartMinute])
}

model PlanQuery {
  id         String           @id @default(cuid())
  language   String
  startAt    DateTime
  includeGeneratedTimes Boolean @default(false)
  preference PlanPreference?
  status     String           @default("READY")
  places     PlanQueryPlace[]
  candidates PlanCandidate[]
  createdAt  DateTime         @default(now())
}

model PlanQueryPlace {
  id                    String    @id @default(cuid())
  planQueryId           String
  placeId               String?
  externalProvider      String?
  externalRef           String?
  externalDisplayName   String?
  externalRegionName    String?
  externalCategoryLabel String?
  externalLatitude      Float?
  externalLongitude     Float?
  sequence              Int
  dwellMinutes          Int
  planQuery             PlanQuery @relation(fields: [planQueryId], references: [id], onDelete: Cascade)
  place                 Place?    @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@unique([planQueryId, sequence])
  @@index([placeId])
}

model PlanCandidate {
  id          String             @id @default(cuid())
  planQueryId String
  kind        PlanPreference
  score       Float
  summary     Json
  legs        Json
  warnings    Json?
  createdAt   DateTime           @default(now())
  planQuery   PlanQuery          @relation(fields: [planQueryId], references: [id], onDelete: Cascade)
  sessions    ExecutionSession[]
}

model ExecutionSession {
  id                  String        @id @default(cuid())
  planCandidateId     String
  status              SessionStatus @default(ACTIVE)
  snapshot            Json
  currentLegIndex     Int           @default(0)
  lastRealtimeApplied Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  planCandidate       PlanCandidate @relation(fields: [planCandidateId], references: [id], onDelete: Cascade)
}

model DataSource {
  id          String      @id @default(cuid())
  key         String      @unique
  name        String
  description String
  sourceKind  SourceKind
  officialUrl String
  guideUrl    String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  jobs        IngestJob[]
}

model IngestJob {
  id               String      @id @default(cuid())
  key              String      @unique
  name             String
  scheduleLabel    String
  sourceId         String
  isActive         Boolean     @default(true)
  lastSuccessfulAt DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  source           DataSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  runs             IngestRun[]
}

model IngestRun {
  id            String          @id @default(cuid())
  jobId          String
  status         IngestRunStatus
  triggeredBy    String
  startedAt      DateTime        @default(now())
  endedAt        DateTime?
  processedCount Int             @default(0)
  successCount   Int             @default(0)
  failureCount   Int             @default(0)
  errorSummary   String?
  meta           Json?
  job            IngestJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, startedAt])
}
